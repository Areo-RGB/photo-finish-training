{
  "name": "sprint-sync-tools",
  "private": true,
  "scripts": {
    "build:debug:apk": "cd android && gradlew.bat :app:assembleDebug",
    "build:release:apk": "cd android && gradlew.bat :app:assembleRelease",
    "build:flavor:apks": "npm run build:debug:apk",
    "install:flavor:devices": "npm run install:debug:devices",
    "run:flavor:devices": "npm run run:debug:devices",
    "rebuild:flavor:devices": "npm run rebuild:debug:devices",
    "install:debug:devices": "node scripts/install-debug-device-flavors-adb-install-only.mjs",
    "run:debug:devices": "node scripts/install-debug-device-flavors-adb.mjs",
    "rebuild:debug:devices": "npm run build:debug:apk && npm run install:debug:devices",
    "install:release:devices": "node scripts/install-release-apk.mjs",
    "rebuild:release:devices": "npm run build:release:apk && node scripts/install-release-apk.mjs",
    "install:debug:devices:build": "npm run rebuild:debug:devices"
  }
}
